@baseUrl = http://localhost:8080

### =========================================
### STEP 0. 테스트 계정 정보
### 예치금이 0이면 deposit-test-direct.http 먼저 실행
### =========================================
@email = test02@example.com
@password = Password123!

### =========================================
### STEP 1. 로그인 → 토큰 자동 저장
### =========================================
POST {{baseUrl}}/api/member/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

> {%
  if (response.status === 200 && response.body.data) {
    client.global.set("accessToken", response.body.data.accessToken);
    client.global.set("memberId", response.body.data.memberId);
    client.global.set("idemKeyCart", "order-cart-" + Math.random().toString(36).substring(2, 10));
    client.global.set("idemKeyDirect", "order-direct-" + Math.random().toString(36).substring(2, 10));
    client.global.set("idemKeyFailBalance", "order-fail-balance-" + Math.random().toString(36).substring(2, 10));
    client.global.set("idemKeyFailStock", "order-fail-stock-" + Math.random().toString(36).substring(2, 10));
  } else {
    client.log("로그인 실패: " + response.status + " / " + JSON.stringify(response.body));
  }
%}


### =========================================
### STEP 2. 결제 전 예치금 잔액 조회
### =========================================
GET {{baseUrl}}/api/member/member/me/deposit
Authorization: Bearer {{accessToken}}


### =========================================
### STEP 3. 배송지 등록 → addressId 자동 저장
### 이미 등록된 경우 409가 와도 무시하고 STEP 4에서 조회
### =========================================
POST {{baseUrl}}/api/member/member/address
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "label": "집",
  "recipient": "테스트유저",
  "phone": "01012345678",
  "zipcode": "12345",
  "address1": "서울시 강남구 테스트로 1",
  "address2": "101호"
}

> {%
  if ((response.status === 200 || response.status === 201) && response.body.data) {
    client.global.set("addressId", response.body.data.addressId);
  }
%}


### =========================================
### STEP 4. 배송지 목록 조회 → addressId 확인
### STEP 3에서 저장 실패(409 등)한 경우 여기서 저장
### =========================================
GET {{baseUrl}}/api/member/member/address
Authorization: Bearer {{accessToken}}

> {%
  if (response.status === 200 && response.body.data && response.body.data.length > 0) {
    client.global.set("addressId", response.body.data[0].addressId);
  } else {
    client.log("배송지 없음 — STEP 3 배송지 등록을 먼저 실행하세요.");
  }
%}


### =========================================
### STEP 5. 상품 목록 조회 → productId 자동 저장
### =========================================
GET {{baseUrl}}/api/product/products
Authorization: Bearer {{accessToken}}

> {%
  if (response.status === 200 && response.body.data && response.body.data.length > 0) {
    client.global.set("productId", response.body.data[0].productId);
  } else {
    client.log("상품 없음 — product-service에 상품을 먼저 등록하세요.");
  }
%}


### =========================================
### ====== Flow A: 장바구니 경유 결제 ======
### =========================================

### STEP 6-A. 장바구니에 상품 담기
POST {{baseUrl}}/api/order/order/cart/item
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "productId": "{{productId}}",
  "quantity": 1
}


### STEP 7-A. 장바구니 조회 → cartItemId 자동 저장
GET {{baseUrl}}/api/order/order/cart
Authorization: Bearer {{accessToken}}

> {%
  if (response.status === 200 && response.body.data) {
    const items = response.body.data.items;
    if (items && items.length > 0) {
      client.global.set("cartItemId", items[0].cartItemId);
    } else {
      client.log("장바구니가 비어 있습니다.");
    }
  } else {
    client.log("장바구니 조회 실패: " + response.status + " / " + JSON.stringify(response.body));
  }
%}


### STEP 8-A. 결제 페이지 정보 조회 (장바구니 경로)
GET {{baseUrl}}/api/order/order/checkout?cartItemIds={{cartItemId}}
Authorization: Bearer {{accessToken}}


### STEP 9-A. 주문 생성 (장바구니 경유) → orderId 자동 저장
POST {{baseUrl}}/api/order/order
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "items": [
    {
      "productId": "{{productId}}",
      "quantity": 1,
      "cartItemId": "{{cartItemId}}"
    }
  ],
  "addressId": "{{addressId}}",
  "idempotencyKey": "{{idemKeyCart}}"
}

> {%
  if (response.status === 201 && response.body.data) {
    client.global.set("orderIdFromCart", response.body.data.orderId);
  } else {
    client.log("주문 생성 실패: " + response.status + " / " + JSON.stringify(response.body));
  }
%}


### STEP 10-A. 결제 실행 (장바구니 경유)
### 예치금 차감 → 재고 차감 → 주문 PAID + 장바구니 항목 자동 삭제
POST {{baseUrl}}/api/payment/payment/orders/{{orderIdFromCart}}/pay
Authorization: Bearer {{accessToken}}


### STEP 11-A. 결제 후 장바구니 재조회 → 해당 항목 삭제 여부 확인
GET {{baseUrl}}/api/order/order/cart
Authorization: Bearer {{accessToken}}


### =========================================
### ======= Flow B: 바로 결제 =======
### =========================================

### STEP 6-B. 결제 페이지 정보 조회 (바로 결제 경로)
GET {{baseUrl}}/api/order/order/checkout?productId={{productId}}&quantity=1
Authorization: Bearer {{accessToken}}


### STEP 7-B. 주문 생성 (바로 결제) → orderId 자동 저장
POST {{baseUrl}}/api/order/order
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "items": [
    {
      "productId": "{{productId}}",
      "quantity": 1
    }
  ],
  "addressId": "{{addressId}}",
  "idempotencyKey": "{{idemKeyDirect}}"
}

> {%
  if (response.status === 201 && response.body.data) {
    client.global.set("orderIdDirect", response.body.data.orderId);
  } else {
    client.log("주문 생성 실패: " + response.status + " / " + JSON.stringify(response.body));
  }
%}


### STEP 8-B. 결제 실행 (바로 결제)
POST {{baseUrl}}/api/payment/payment/orders/{{orderIdDirect}}/pay
Authorization: Bearer {{accessToken}}


### =========================================
### ========= 결제 후 검증 =========
### =========================================

### STEP 9. 결제 후 예치금 잔액 조회
### 결제 전 잔액 - 주문 총액 = 결제 후 잔액 확인
GET {{baseUrl}}/api/member/member/me/deposit
Authorization: Bearer {{accessToken}}


### STEP 10. 예치금 내역 조회 — USE 타입 확인
GET {{baseUrl}}/api/payment/payment/deposit/history?type=USE
Authorization: Bearer {{accessToken}}


### STEP 11. 주문 상세 조회 — 상태 PAID 확인
GET {{baseUrl}}/api/order/order/{{orderIdDirect}}
Authorization: Bearer {{accessToken}}


### =========================================
### ========= 오류 케이스 =========
### =========================================

### [오류 1] 이미 결제된 주문 재결제 시도
### → 400 또는 409
POST {{baseUrl}}/api/payment/payment/orders/{{orderIdDirect}}/pay
Authorization: Bearer {{accessToken}}


### [오류 2] 잔액 부족 결제 시도
### 사전 조건: 주문 금액 > 현재 예치금 잔액
### → 400 DEPOSIT_INSUFFICIENT_BALANCE
POST {{baseUrl}}/api/order/order
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "items": [
    {
      "productId": "{{productId}}",
      "quantity": 99999
    }
  ],
  "addressId": "{{addressId}}",
  "idempotencyKey": "{{idemKeyFailBalance}}"
}

> {%
  if (response.status === 201 && response.body.data) {
    client.global.set("orderIdInsufficientBalance", response.body.data.orderId);
  } else {
    client.log("주문 생성 실패: " + response.status + " / " + JSON.stringify(response.body));
  }
%}

###
POST {{baseUrl}}/api/payment/payment/orders/{{orderIdInsufficientBalance}}/pay
Authorization: Bearer {{accessToken}}


### [오류 3] 이메일 미인증 계정으로 결제 시도
### → 403 EMAIL_NOT_VERIFIED
### 사전 조건: 이메일 미인증 계정으로 로그인 후 실행
### 주의: gateway가 JWT에서 email_verified를 덮어쓰므로 실제 미인증 계정 필요
POST {{baseUrl}}/api/payment/payment/orders/{{orderIdDirect}}/pay
Authorization: Bearer {{accessToken}}


### [오류 4] 재고 부족 결제 시도
### → 재고 차감 실패, 예치금 환불 보상 트랜잭션 실행
POST {{baseUrl}}/api/order/order
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "items": [
    {
      "productId": "{{productId}}",
      "quantity": 99999
    }
  ],
  "addressId": "{{addressId}}",
  "idempotencyKey": "{{idemKeyFailStock}}"
}

> {%
  if (response.status === 201 && response.body.data) {
    client.global.set("orderIdOutOfStock", response.body.data.orderId);
  } else {
    client.log("주문 생성 실패: " + response.status + " / " + JSON.stringify(response.body));
  }
%}

###
POST {{baseUrl}}/api/payment/payment/orders/{{orderIdOutOfStock}}/pay
Authorization: Bearer {{accessToken}}
