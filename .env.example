# Database
DB_URL=jdbc:postgresql://localhost:5432/bookcommerce
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET_KEY=your_jwt_secret_key_must_be_32_chars_minimum

# Internal API
INTERNAL_SECRET_KEY=your_internal_service_secret_key_here

# Admin
ADMIN_EMAIL=your_admin_email_here
ADMIN_PASSWORD=your_admin_password_here

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Payment - Encryption (AES-256-GCM, Base64 encoded 32-byte key)
PAYMENT_ENCRYPTION_KEY=your_base64_encoded_32byte_key_here

# Payment - Toss PG
TOSS_CLIENT_KEY=test_ck_your_toss_client_key
TOSS_SECRET_KEY=test_sk_your_toss_secret_key
TOSS_SUCCESS_URL=http://localhost:8084/success.html
TOSS_FAIL_URL=http://localhost:8084/fail.html

# docker-compose 로컬 테스트용
GHCR_OWNER=prgrms-be-adv-devcourse
